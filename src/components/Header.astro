---
// Header.astro

import NavItem from "./NavItem.tsx";
import { SearchBar } from "./SearchBar.tsx";

interface Props {
	currentPath?: string;
	centerText?: string;
}

const { currentPath = "/", centerText = "" } = Astro.props;

const navItems = [
	{ label: "Blog", windowName: "blog" },
	{ label: "About", windowName: "about" },
	{ label: "Contact", windowName: "contact" },
];
---

<script is:inline>
    const CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
    const activeAnimations = new WeakMap();

    function getRandomChar() {
        return CHARS[Math.floor(Math.random() * CHARS.length)];
    }

    function shuffleText(element) {
        // Cancel any existing animation on this element
        if (activeAnimations.has(element)) {
            clearInterval(activeAnimations.get(element));
        }

        const originalText = element.dataset.originalText || element.textContent;
        element.dataset.originalText = originalText;

        const textLength = originalText.length;
        const duration = 600;
        const frameRate = 50;
        const totalFrames = Math.ceil(duration / frameRate);
        let currentFrame = 0;

        const interval = setInterval(() => {
            let displayText = '';
            const progress = currentFrame / totalFrames;
            const revealCount = Math.floor(textLength * progress);

            for (let i = 0; i < textLength; i++) {
                if (i < revealCount) {
                    displayText += originalText[i];
                } else {
                    displayText += getRandomChar();
                }
            }

            element.textContent = displayText;
            currentFrame++;

            if (currentFrame > totalFrames) {
                clearInterval(interval);
                activeAnimations.delete(element);
                element.textContent = originalText;
            }
        }, frameRate);

        activeAnimations.set(element, interval);
    }

    document.addEventListener('DOMContentLoaded', () => {
        // Find the header and only target leaf elements that contain text
        const header = document.querySelector('.site-header');
        if (!header) return;

        const targets = Array.from(header.querySelectorAll('*')).filter(el => {
            if (el.children.length > 0) return false;
            const txt = (el.textContent || '').trim();
            return txt.length > 0;
        });

        targets.forEach(el => shuffleText(el));

        // Mobile nav hamburger menu
        const overlay = document.querySelector('.mobile-nav-overlay');
        const menuBtn = document.querySelector('.mobile-menu-btn');
        const closeBtn = document.querySelector('.mobile-nav-close');
        const backdrop = document.querySelector('.mobile-nav-backdrop');
        const navLinks = document.querySelectorAll('.mobile-nav-links [data-window-name]');

        function openMenu() {
            if (!overlay) return;
            overlay.classList.add('is-open');
            overlay.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function closeMenu() {
            if (!overlay) return;
            overlay.classList.remove('is-open');
            overlay.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        if (menuBtn) menuBtn.addEventListener('click', openMenu);
        if (closeBtn) closeBtn.addEventListener('click', closeMenu);
        if (backdrop) backdrop.addEventListener('click', closeMenu);
        navLinks.forEach(link => link.addEventListener('click', () => {
            setTimeout(closeMenu, 150);
        }));
    });
</script>

<header class="site-header">
    <div class="header-container">
        <div class="header-name">
            <span class="name">
                genr234
            </span>
        </div>

        <span class="header-center">
            {centerText}
        </span>

        <nav class="header-nav" data-tutorial="header-nav">
            <SearchBar client:load />
            {navItems.map(item => (
                    <NavItem
                            label={item.label}
                            windowName={item.windowName}
                            client:load
                    />
            ))}
        </nav>

        <div class="mobile-search-btn">
            <SearchBar client:load />
        </div>
        <button class="mobile-menu-btn" aria-label="Open menu">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="6" x2="21" y2="6" />
                <line x1="3" y1="12" x2="21" y2="12" />
                <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
        </button>
    </div>
</header>

<div class="mobile-nav-overlay" aria-hidden="true">
    <div class="mobile-nav-backdrop"></div>
    <div class="mobile-nav-panel">
        <div class="mobile-nav-header">
            <span class="mobile-nav-title">Menu</span>
            <button class="mobile-nav-close" aria-label="Close menu">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
            </button>
        </div>
        <nav class="mobile-nav-links">
            {navItems.map(item => (
                <NavItem
                    label={item.label}
                    windowName={item.windowName}
                    client:load
                />
            ))}
        </nav>
    </div>
</div>

<style lang="scss">
    .site-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background: transparent;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    .header-container {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        padding: 12px 20px;
        max-width: 100%;
        font-family: Gentle, sans-serif;
        background: transparent;
    }

    .header-name {
        justify-self: start;
        mix-blend-mode: normal;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        width: fit-content;
    }

    .name {
        text-decoration: none;
        font-family: Jack, sans-serif;
        font-size: 1.125rem;
        font-weight: 100;
        display: inline-block;
        letter-spacing: 0.01em;
        color: #ffffff;
        mix-blend-mode: difference;
        -webkit-text-fill-color: currentColor;
        position: relative;
        z-index: auto;
        flex-shrink: 0;
        opacity: 0.6;
        transition: all 0.3s ease;
        cursor: pointer;

        &:hover {
            opacity: 1;
            font-weight: 400;
        }
    }

    .search-container {
        display: flex;
        flex-shrink: 0;
    }

    .header-center,
    .header-nav {
        mix-blend-mode: normal;
    }

    .header-nav {
        /* keep nav container layout scoped */
        justify-self: end;
        display: flex;
        gap: 2rem;
        position: relative;
        text-align: center;
        align-items: center;
        z-index: 1010; /* sit above background canvas but below cursor (9999) */
    }

    .header-nav :global(*) {
        mix-blend-mode: normal !important;
    }

    .header-nav > * {
        mix-blend-mode: normal !important;
       color: #0d0d0d !important;
       opacity: 0.9 !important;
        position: relative;
    }


    /* Hamburger button — hidden on desktop */
    .mobile-menu-btn {
        display: none;
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        color: #ffffff;
        mix-blend-mode: difference;
        opacity: 0.7;
        transition: opacity 0.2s ease;
        -webkit-tap-highlight-color: transparent;

        &:hover,
        &:active {
            opacity: 1;
        }
    }

    /* Mobile search button — hidden on desktop */
    .mobile-search-btn {
        display: none;
    }

    /* Mobile nav overlay */
    .mobile-nav-overlay {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 2000;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.25s ease;

        &.is-open {
            pointer-events: auto;
            opacity: 1;
        }
    }

    .mobile-nav-backdrop {
        position: absolute;
        inset: 0;
        -webkit-backdrop-filter: blur(20px);
      box-shadow:
              0 12px 48px rgba(0, 0, 0, 0.12),
              0 4px 16px rgba(0, 0, 0, 0.08);
      backdrop-filter: blur(20px);
    }

    .mobile-nav-panel {
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        width: 280px;
        max-width: 80vw;
        box-shadow:
              0 12px 48px rgba(0, 0, 0, 0.12),
              0 4px 16px rgba(0, 0, 0, 0.08);
        backdrop-filter: blur(20px);
        display: flex;
        flex-direction: column;
        transform: translateX(100%);
        transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    }

    .mobile-nav-overlay.is-open .mobile-nav-panel {
        transform: translateX(0);
    }

    .mobile-nav-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .mobile-nav-title {
        font-family: Gentle, sans-serif;
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.5);
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .mobile-nav-close {
        background: none;
        border: none;
        padding: 4px;
        cursor: pointer;
        color: rgba(255, 255, 255, 0.6);
        transition: color 0.15s ease;
        -webkit-tap-highlight-color: transparent;

        &:hover,
        &:active {
            color: #ffffff;
        }
    }

    .mobile-nav-links {
        display: flex;
        flex-direction: column;
        padding: 12px 0;

        :global(.navItem),
        :global([data-window-name]) {
            display: block;
            padding: 14px 24px;
            font-size: 1.125rem;
            color: rgba(255, 255, 255, 0.85) !important;
            opacity: 1 !important;
            mix-blend-mode: normal !important;
            transition: background 0.15s ease;

            &:hover,
            &:active {
                background: rgba(255, 255, 255, 0.06);
            }
        }
    }

    @media (max-width: 768px) {
        .header-container {
            grid-template-columns: 1fr auto auto;
            gap: 0;
            padding: 10px 16px;
        }

        .header-center {
            display: none;
        }

        .header-name {
            justify-self: start;
        }

        .header-nav {
            display: none;
        }

        .mobile-search-btn {
            display: flex;
            align-items: center;
            justify-self: end;
        }

        .mobile-menu-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            justify-self: end;
        }

        .mobile-nav-overlay {
            display: block;
        }
    }
</style>